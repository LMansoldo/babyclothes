@import url('@babyclothes/ui/tokens.css');

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  background: var(--color-bg);
  color: var(--color-black);
  font-family: var(--font-body);
  font-size: 1.4rem;
  line-height: 1.6;
}
