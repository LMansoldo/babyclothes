# PostgreSQL
DATABASE_URL=postgres://babyclothes:babyclothes@localhost:5432/babyclothes_dev

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
JWT_SECRET=change-me-in-production-min-32-chars

# Internal service auth
INTERNAL_API_KEY=change-me-shared-secret

# gRPC
GRPC_AGENT_URL=localhost:50051

# S3 / Cloudflare R2
S3_BUCKET=babyclothes-dev
S3_REGION=auto
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# Anthropic (LLM)
ANTHROPIC_API_KEY=your-anthropic-key

# Internal API URL (used by agents service)
INTERNAL_API_URL=http://localhost:4000

# SvelteKit public vars
PUBLIC_API_URL=http://localhost:4000
